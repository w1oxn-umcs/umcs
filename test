    if not folder then return nil, 0 end
    local parts = folder:GetChildren()
    local partCount = #parts
    if partCount == 0 then return nil, 0 end
    local sum = Vector3.new(0,0,0)
    local count = 0
    for _, p in ipairs(parts) do
        if p:IsA("BasePart") then
            sum = sum + p.Position
