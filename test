    Desc  = '5 trap modes: Spleef, Delete, Toxify, Disco, Guess-the-X. Select blocks → players touching them trigger the action.',
    Callback = function()
        createtraptool().Parent = (plr.Character and not plr.Character:FindFirstChildWhichIsA("Tool") and plr.Character) or plr.Backpack
        WindUI:Notify({ Title = "pealzware", Content = "Trap Editor tool added to backpack", Duration = 3, Icon = "info" })
