function doRestoreBuilding(delay)

    if not game.ReplicatedStorage:FindFirstChild(brickname) then
        local brick = Instance.new("Part")
        brick.Name = brickname
        brick.Parent = game.ReplicatedStorage
    end

    for _, v in pairs(localplr.Character:GetChildren()) do
        if v:HasTag("The Chosen One by TomazDev") then
            v.Script.Enabled = false
            v.Script.Enabled = true
        end
    end
    for _, v in pairs(localplr.Backpack:GetChildren()) do
        if v:HasTag("The Chosen One by TomazDev") then
            v.Script.Enabled = false
            v.Script.Enabled = true
        end
    end
    if isog then
        pcall(function() localplr.Backpack.BTools.Enabled = false; localplr.Backpack.BTools.Enabled = true end)
    end

    local et = equiptool("Build")
    if not et then
        WindUI:Notify({ Title = "pealzware", Content = "Build tool not found!", Duration = 3, Icon = "info" })
        return false
    end

    task.wait(delay or 0)

    local currbc = {}
    local ins = 1
    for i, v in pairs(getgenv().brickcollection) do
        if v ~= nil then
            if v:GetFullName() ~= brickname and v.Name ~= "Debris" then
                table.insert(currbc, 1, v)
                ins = ins + 1
            else
                if i % 2 == 1 then
                    table.insert(currbc, v)
                else
                    table.insert(currbc, ins, v)
                end
            end
        else
            table.remove(getgenv().brickcollection, table.find(getgenv().brickcollection, v))
        end
    end

    local block = nil
    local beforeamt = #cfolder[localplr.Name]:GetChildren()

    for i, v in pairs(currbc) do
        if v ~= nil and typeof(v) == "Instance" then
            et = equiptool("Build")
            if not et then
                WindUI:Notify({ Title = "pealzware", Content = "Build tool not found. Retry when it comes back.", Duration = 5, Icon = "info" })
                break
            end

            block = v
            if isog then
                pcall(function()
                    localplr.Backpack.Events:FireServer(
                        getplrpos(),
                        Enum.NormalId.Top,
                        block,
                        Color3.new(0, 0, 0),
                        "Smooth"
                    )
                end)
            else
                et.Script.Event:FireServer(
                    block,
                    Enum.NormalId.Top,
                    getplrpos(),
                    "detailed"
                )
            end

            task.wait(delay or 0)

            if beforeamt < #cfolder[localplr.Name]:GetChildren() then
                break
            end
        else
            table.remove(currbc, table.find(currbc, v))
        end
    end

    task.wait(1)
    block = cfolder[localplr.Name]:FindFirstChildWhichIsA("BasePart")
    if not block then
        return false
    end

    local function fireTool(toolName, args)
        local char = localplr.Character
        if not char then return false end
        local tool = char:FindFirstChild(toolName)
        if not tool then
            local bpTool = localplr.Backpack:FindFirstChild(toolName)
            if bpTool then bpTool.Parent = char; tool = char:FindFirstChild(toolName) end
        end
        if not tool then return false end
        local ev = tool:FindFirstChild("origevent")
        if ev then return pcall(function() ev:Invoke(table.unpack(args)) end) end
        if tool:FindFirstChild("Script") and tool.Script:FindFirstChild("Event") then
            return pcall(function() tool.Script.Event:FireServer(table.unpack(args)) end)
        end
        return false
    end

    if block.Material ~= Enum.Material.Plastic then
        fireTool("Paint", { block, Enum.NormalId.Top, getplrpos(),
                            "material", Color3.fromRGB(192, 192, 192), "plastic", "" })
        task.wait(resizewait * 2)
    end

    if not block.Anchored or (block.CFrame - block.Position) ~= CFrame.new() then
        local nextToggle = 0
        local tries = 0
        repeat
            if tick() >= nextToggle then
                nextToggle = tick() + (resizewait * 2)
                tries = tries + 1
                fireTool("Paint", { block, Enum.NormalId.Top, getplrpos(),
                                    "both \u{1F91D}", Color3.fromRGB(192, 192, 192), "anchor", "" })
            end
                    until (not block) or (not block.Parent)
            or (block.Anchored and (block.CFrame - block.Position) == CFrame.new())
            or tries > 8
    end

    if block and block.Parent and block.Size == Vector3.new(1, 1, 1) then
        local pos      = block.Position
        local offsetX  = (pos.X % gridSize) - 0.5
        local offsetY  = (pos.Y % gridSize) - 0.5
        local offsetZ  = (pos.Z % gridSize) - 0.5
        local growSlots = gridSize - 1

        local function growN(face, n)
            for _ = 1, math.floor(n) do
                if not block or not block.Parent then return end
                fireTool("Shape", { block, face, getplrpos(), "increase" })
                task.wait(resizewait)
            end
        end

        growN(Enum.NormalId.Left,   offsetX)
        growN(Enum.NormalId.Right,  growSlots - offsetX)
        growN(Enum.NormalId.Bottom, offsetY)
        growN(Enum.NormalId.Top,    growSlots - offsetY)
        growN(Enum.NormalId.Front,  offsetZ)
        growN(Enum.NormalId.Back,   growSlots - offsetZ)
    end

    sendActionWebhook("Restore Building", "User used Restore Building")
    WindUI:Notify({ Title = "pealzware", Content = "Building restored successfully!", Duration = 3, Icon = "info" })
    return true
end

