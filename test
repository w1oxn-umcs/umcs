        ok, resp = pcall(requestFunc, opts)
        if ok and resp and resp.StatusCode and resp.StatusCode < 500 then
            return ok, resp
        end
    end
    if _buildServerUrl ~= "" then
        opts.Url = _buildServerUrl .. path
        ok, resp = pcall(requestFunc, opts)
    end
    return ok, resp
end

