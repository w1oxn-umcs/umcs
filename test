sortBlocksByDistanceFromSpawn = function(buildData)
    local spawnPos = getSpawnPosition()

    for i, block in ipairs(buildData) do
        local posses = block.p or block.pos
        if not posses then
            block.distance = math.huge
            block.originalIndex = i
            continue
        end
        local blockPos = Vector3.new(posses[1], posses[2], posses[3])
        local sizeArr = block.s or block.size
        if sizeArr then
            blockPos = Vector3.new(
                blockPos.X + (sizeArr[1]/2) - 0.5,
                blockPos.Y + (sizeArr[2]/2) - 0.5,
                blockPos.Z + (sizeArr[3]/2) - 0.5
            )
        end
        block.distance = (blockPos - spawnPos).Magnitude
        block.originalIndex = i
    end

    table.sort(buildData, function(a, b)
        return a.distance < b.distance
    end)

    for _, block in ipairs(buildData) do
        block.distance = nil
        block.originalIndex = nil
    end

    return buildData
end
