local _advancedBuildRunGen = 0
local _lastAdvancedBuild = nil
local _buildToolNames = { "Build", "Paint", "Shape", "Delete" }
local _buildPosTolerance = 0.75
local _buildSizeTolerance = 0.75
local _buildColorTolerance = 0.02
local _lastBuildToolNotify = 0

local function _pwNotifyBuild(message, duration)
    if WindUI and WindUI.Notify then
        WindUI:Notify({ Title = "pealzware", Content = message, Duration = duration or 4, Icon = "info" })
    end
end

local function _pwEquipBuildTool(toolName)
    local character = localplr.Character
    if not character then return nil end
    local equipped = character:FindFirstChild(toolName)
    if equipped and equipped:IsA("Tool") then
        return equipped
    end
    local backpack = localplr:FindFirstChildOfClass("Backpack")
    local tool = backpack and backpack:FindFirstChild(toolName)
    if tool and tool:IsA("Tool") then
        pcall(function()
            if tool:FindFirstChild("Script") and tool.Script:IsA("LocalScript") then
                tool.Script.Disabled = false
            end
        end)
        pcall(function() tool.Parent = character end)
        return character:FindFirstChild(toolName)
    end
    return nil
end

local function _pwGrabBuildTool(toolName)
    local backpack = localplr:FindFirstChildOfClass("Backpack")
    if not backpack or backpack:FindFirstChild(toolName) then return end
    local worldTool = workspace:FindFirstChild(toolName)
    if worldTool and worldTool:IsA("Tool") then
        pcall(function() worldTool:Clone().Parent = backpack end)
    end
end

ensureBuildTools = function(notifyIfMissing)
    local haveBuild = false
    for _, toolName in ipairs(_buildToolNames) do
        if not _pwEquipBuildTool(toolName) then
            _pwGrabBuildTool(toolName)
            _pwEquipBuildTool(toolName)
        end
        if toolName == "Build" and localplr.Character and localplr.Character:FindFirstChild("Build") then
            haveBuild = true
        end
    end
    if not haveBuild and notifyIfMissing then
        local now = os.clock()
        if now - (_lastBuildToolNotify or 0) > 6 then
            _lastBuildToolNotify = now
            _pwNotifyBuild("Build tool missing. Grant yourself bkit, then retry.", 5)
        end
    end
    return haveBuild
end

local function _pwVectorClose(a, b, tolerance)
    return math.abs(a.X - b.X) <= tolerance
        and math.abs(a.Y - b.Y) <= tolerance
        and math.abs(a.Z - b.Z) <= tolerance
end

local function _pwColorClose(a, b)
    return math.abs(a.R - b.R) <= _buildColorTolerance
        and math.abs(a.G - b.G) <= _buildColorTolerance
        and math.abs(a.B - b.B) <= _buildColorTolerance
end

local function _pwBlockCenter(rawPos, bsize)
    if not bsize then return rawPos end
    return Vector3.new(
        rawPos.X + (bsize.X / 2) - 0.5,
        rawPos.Y + (bsize.Y / 2) - 0.5,
        rawPos.Z + (bsize.Z / 2) - 0.5
    )
end

local function _pwPartMatches(part, centerPos, bsize)
    return part
        and part:IsA("BasePart")
        and _pwVectorClose(part.Position, centerPos, _buildPosTolerance)
        and _pwVectorClose(part.Size, bsize, _buildSizeTolerance)
end

findBuildBlockAt = function(centerPos, bsize)
    if not cfolder or not cfolder.Parent then return nil end
    local size = bsize or Vector3.new(gridSize, gridSize, gridSize)

    local ok, hits = pcall(function()
        local params = OverlapParams.new()
        params.FilterType = Enum.RaycastFilterType.Include
        params.FilterDescendantsInstances = { cfolder }
        params.MaxParts = 30
        return workspace:GetPartBoundsInBox(CFrame.new(centerPos), Vector3.new(1, 1, 1), params)
    end)
    if ok and hits then
        for _, part in ipairs(hits) do
            if _pwPartMatches(part, centerPos, size) then
                return part
            end
        end
    end

    for _, part in ipairs(cfolder:GetDescendants()) do
        if _pwPartMatches(part, centerPos, size) then
            return part
        end
    end
    return nil
end

blockVerified = function(centerPos, bsize, expectColor, expectMat, expectAnchored, expectCollide)
    local part = findBuildBlockAt(centerPos, bsize)
    if not part then return false end
    if expectColor and not _pwColorClose(part.Color, expectColor) then return false end
    if expectMat and part.Material ~= expectMat then return false end
    if expectAnchored ~= nil and part.Anchored ~= expectAnchored then return false end
    if expectCollide ~= nil and part.CanCollide ~= expectCollide then return false end
    return true
end

local function _pwTransformBlockPos(rawPos, bsize, transform)
    if not transform or not transform.enabled then
        return rawPos
    end
    local halfOff = Vector3.new(bsize.X / 2 - 0.5, bsize.Y / 2 - 0.5, bsize.Z / 2 - 0.5)
    local buildCenter = transform.center or Vector3.zero
    local rotation = transform.rotation or CFrame.identity
    local offset = transform.offset or Vector3.zero
    local origCenter = rawPos + halfOff
    local relPos = origCenter - buildCenter
    local newCenter = buildCenter + (rotation * relPos) + offset
    return newCenter - halfOff
end

local function _pwResolveBuildBlock(v, transform)
    local posses = v and (v.p or v.pos)
    if not posses then return nil end
    local sizeArr = v.s or v.size
    local bsz = sizeArr and Vector3.new(table.unpack(sizeArr)) or Vector3.new(gridSize, gridSize, gridSize)
    local rawPos = Vector3.new(posses[1], posses[2], posses[3])
    local pos = _pwTransformBlockPos(rawPos, bsz, transform)
    local col = (v.c or v.color) and Color3.fromRGB(table.unpack(v.c or v.color)) or defaultcolor
    local matName = v.m or v.mat
    local origMat = v.o or v.origmat
    local expectMat = swappedmaterials[matName] or Enum.Material.SmoothPlastic
    if not swappedmaterials[matName] and origMat then
        pcall(function()
            expectMat = Enum.Material[origMat] or expectMat
        end)
    end
    local anchored = v.a
    if anchored == nil then anchored = v.anchored end
    if anchored == nil then anchored = true end
    local collide = v.cc
    if collide == nil then collide = v.collide end
    if collide == nil then collide = true end

    local center = pos
    if sizeArr then
        center = _pwBlockCenter(pos, bsz)
    end

    return {
        pos = pos,
        size = bsz,
        color = col,
        matName = matName,
        expectMat = expectMat,
        center = center,
        anchored = anchored,
        collide = collide,
    }
end

local function _pwPlaceAndVerifyBuildBlock(v, transform)
    local resolved = _pwResolveBuildBlock(v, transform)
    if not resolved then return true end

    if blockVerified(resolved.center, resolved.size, resolved.color, resolved.expectMat, resolved.anchored, resolved.collide) then
        return true
    end

    ensureBuildTools(true)
    createpartrepl(resolved.pos, resolved.size, resolved.color, resolved.expectMat)
    buildblock(
        resolved.pos,
        resolved.matName,
        resolved.color,
        nil,
        resolved.size,
        true,
        v.o or v.origmat,
        v.sp or v.sprayed,
        resolved.anchored,
        resolved.collide
    )

    task.wait(math.max(0.03, buildDelay or 0.05))
    return blockVerified(resolved.center, resolved.size, resolved.color, resolved.expectMat, resolved.anchored, resolved.collide)
end

stopAdvancedAutoBuild = function()
    stopped = true
    skipblock = true
    _advancedBuildRunGen = _advancedBuildRunGen + 1
end

runAdvancedAutoBuild = function(buildData, opts)
    if type(buildData) ~= "table" or #buildData == 0 then
        _pwNotifyBuild("Build JSON invalid or empty.", 5)
        return false
    end
    if not ensureBuildTools(true) then
        return false
    end

    opts = opts or {}
    local transform = opts.transform
    local blocks = {}
    for i, block in ipairs(buildData) do
        blocks[i] = block
    end
    blocks = sortBlocksByDistanceFromSpawn(blocks)

    _advancedBuildRunGen = _advancedBuildRunGen + 1
    local myGen = _advancedBuildRunGen
    _lastAdvancedBuild = {
        blocks = buildData,
        opts = opts,
    }

    stopped = false
    skipblock = false
    totalBuildBlocks = #blocks
    currentBlockIndex = 0
    _buildStartTime = tick()
    updateBuildProgress()

    task.spawn(function()
        local verified = {}
        local verifiedCount = 0
        local function aborted()
            return stopped or _advancedBuildRunGen ~= myGen
        end
        local function markVerified(index)
            if not verified[index] then
                verified[index] = true
                verifiedCount = verifiedCount + 1
                currentBlockIndex = verifiedCount
                updateBuildProgress()
            end
        end

        for i, v in ipairs(blocks) do
            if aborted() then break end
            if i % 25 == 0 then ensureBuildTools(false) end
            if _pwPlaceAndVerifyBuildBlock(v, transform) then
                markVerified(i)
            end
            task.wait(math.max(0.03, buildDelay or 0.05))
        end

        local repairPass = 0
        while not aborted() and verifiedCount < #blocks and repairPass < 4 do
            repairPass = repairPass + 1
            local repairedThisPass = 0
            for i, v in ipairs(blocks) do
                if aborted() then break end
                if not verified[i] then
                    if _pwPlaceAndVerifyBuildBlock(v, transform) then
                        markVerified(i)
                        repairedThisPass = repairedThisPass + 1
                    end
                    task.wait(math.max(0.03, buildDelay or 0.05))
                end
            end
            if repairedThisPass == 0 then break end
        end

        local abortedNow = aborted()
        local missing = #blocks - verifiedCount
        if _advancedBuildRunGen == myGen then
            stopped = false
            skipblock = false
        end
        totalBuildBlocks = 0
        currentBlockIndex = 0
        updateBuildProgress()

        if abortedNow then
            _pwNotifyBuild("Build stopped.", 3)
        elseif missing > 0 then
            _pwNotifyBuild(string.format("Build finished: %d / %d verified (%d need manual attention).", verifiedCount, #blocks, missing), 7)
        else
            _pwNotifyBuild(string.format("Build complete and verified: %d / %d blocks.", verifiedCount, #blocks), 5)
        end
    end)

    return true
end

repairLastAdvancedBuild = function()
    if not _lastAdvancedBuild or not _lastAdvancedBuild.blocks then
        _pwNotifyBuild("No previous build to repair.", 4)
        return false
    end
    return runAdvancedAutoBuild(_lastAdvancedBuild.blocks, _lastAdvancedBuild.opts or {})
end

