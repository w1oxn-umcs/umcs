        end

        processing = true
        bhl.Color3 = Color3.fromRGB(0, 200, 0)
        bhl.SurfaceColor3 = Color3.fromRGB(0, 200, 0)
        local src = mouse.Target

        local ok = pcall(function()

            local mat = materials and materials[src.Material] or "plastic"
            if mat == "neon" then mat = "toxic" end
            _repFirePaint({ brick, Enum.NormalId.Top, getplrpos(),
                            "both \u{1F91D}", src.Color, mat, "" })
            task.wait(0.25)

            if src.Anchored ~= brick.Anchored then
                _repFirePaint({ brick, Enum.NormalId.Top, getplrpos(),
                                "material", Color3.new(), "anchor", "" })
                task.wait(0.25)
            end
            if src.CanCollide ~= brick.CanCollide then
                _repFirePaint({ brick, Enum.NormalId.Top, getplrpos(),
                                "material", Color3.new(), "collide", "" })
                task.wait(0.25)
            end

            local pendingFaces = { Back=true, Front=true, Left=true, Right=true, Top=true, Bottom=true }
            for _, child in ipairs(src:GetChildren()) do
                if child:IsA("SurfaceGui") then
                    local face = child.Face
                    local lbl = child:FindFirstChild("Label") or child:FindFirstChildWhichIsA("TextLabel")
                    if face and lbl then
                        pendingFaces[face.Name] = nil
                        _repFirePaint({ brick, face, getplrpos(),
                                        "both \u{1F91D}", lbl.TextColor3 or Color3.new(), "spray", lbl.Text or "" })
                        task.wait(0.5)
                    end
                end
            end
            for faceName, _ in pairs(pendingFaces) do
                _repFirePaint({ brick, Enum.NormalId[faceName], getplrpos(),
                                "material", Color3.new(), "spray", "" })
                task.wait(0.35)
            end
        end)

        processing = false
        bhl.Color3 = Color3.fromRGB(255, 230, 0)
        bhl.SurfaceColor3 = Color3.fromRGB(255, 230, 0)
        WindUI:Notify({ Title = "pealzware", Content = ok and "Block replicated to ReplicatedStorage.Brick" or "Replication failed", Duration = 3, Icon = "info" })
    end))

    local _repHoverT = 0
    table.insert(connections, RunService.Heartbeat:Connect(function(dt)
        if processing then return end
        _repHoverT = _repHoverT + dt
        if _repHoverT < 0.05 then return end
        _repHoverT = 0
        if equipped and mouse.Target and IsSelectable(mouse.Target, mouse.Hit.Position) then
            bhl.Adornee = mouse.Target
        else
            bhl.Adornee = nil
        end
    end))

    table.insert(connections, cur.AncestryChanged:Connect(function()
        if not cur.Parent or not cur.Parent.Parent then
            for _, c in pairs(connections) do pcall(function() c:Disconnect() end) end
            pcall(function() bhl:Destroy() end)
        end
    end))

    table.insert(tools, { cur, bhl })
    cur.Parent = localplr.Backpack
    return cur
end

