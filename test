    for block, data in pairs(trapBlocks[trapSelMode]) do
        if not data.Active then
            if data.SelectionBox then pcall(function() data.SelectionBox:Destroy() end) end
            trapBlocks[trapSelMode][block] = nil
        else
            if data.SelectionBox then data.SelectionBox.LineThickness = -1 end
        end
    end
    TrapInfo.Text = "Selection cancelled"
    _trapUpdateUI()
end)

createToolButton(_trapPanel.frame, "Remove Mode Blocks", 0.67, 0.03, 0.94, function()
