    local _updAck  -- forward decl: marks the current update acknowledged (defined below)

    -- Draggable via the title bar (mouse + touch). Dragging the window counts
    -- as acknowledging the update, same as closing it.
    do
        local dragging, moved, dragStart, startPos
        local function begin(input)
            dragging = true; moved = false; dragStart = input.Position; startPos = _updPanel.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                    if moved and _updAck then _updAck() end
                end
            end)
        end
        _updBar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1
               or input.UserInputType == Enum.UserInputType.Touch then begin(input) end
        end)
        game:GetService("UserInputService").InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
               or input.UserInputType == Enum.UserInputType.Touch) then
                local d = input.Position - dragStart
                if math.abs(d.X) + math.abs(d.Y) > 4 then moved = true end
                _updPanel.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X,
                                               startPos.Y.Scale, startPos.Y.Offset + d.Y)
            end
        end)
    end

    local _updCache  = nil
    local _updCards  = {}
    local _updUrl    = _relayUrl .. "/updates"

    -- Seen-version tracking: auto-open only when the latest version differs from
    -- what was acknowledged last time. Acknowledged = user closes or drags it.
    local _updSeenPath = "PWCache/updates_seen.txt"
    local _updLatestVer = nil   -- newest version from the most recent fetch
    local function _updReadSeen()
        if isfile and isfile(_updSeenPath) then
            local ok, v = pcall(readfile, _updSeenPath)
            if ok and type(v) == "string" then return (v:gsub("%s+$", "")) end
        end
        return ""
    end
    local function _updMarkSeen()
        if _updLatestVer and _updLatestVer ~= "" then
            pcall(function()
                pcall(makefolder, "PWCache")
                writefile(_updSeenPath, _updLatestVer)
            end)
        end
    end
    _updAck = _updMarkSeen  -- wire the drag-end acknowledgement to the seen-writer

    local function _updCard(order, headerText, bodyText, isHeader)
        local card = Instance.new("Frame")
        card.Size                   = UDim2.new(1, -4, 0, 0)
        card.AutomaticSize          = Enum.AutomaticSize.Y
        card.BackgroundColor3       = _updTheme.Card
        card.BackgroundTransparency = isHeader and 1 or 0.45
        card.BorderSizePixel        = 0
        card.LayoutOrder            = order
        card.ZIndex                 = 6
        card.Parent                 = _updScroll
        if not isHeader then
            Instance.new("UICorner", card).CornerRadius = UDim.new(0, 12)
            local cs = Instance.new("UIStroke")
            cs.Color = _updTheme.Outline
            cs.Transparency = 0.82
            cs.Thickness = 1
            cs.Parent = card
        end
        local pad = Instance.new("UIPadding")
        pad.PaddingTop = UDim.new(0, isHeader and 2 or 10)
        pad.PaddingBottom = UDim.new(0, isHeader and 2 or 10)
        pad.PaddingLeft = UDim.new(0, 12)
        pad.PaddingRight = UDim.new(0, 12)
        pad.Parent = card
        local layout = Instance.new("UIListLayout")
        layout.Padding = UDim.new(0, 4)
        layout.SortOrder = Enum.SortOrder.LayoutOrder
        layout.Parent = card

        local h = Instance.new("TextLabel")
        h.BackgroundTransparency = 1
        h.Size            = UDim2.new(1, 0, 0, 0)
        h.AutomaticSize   = Enum.AutomaticSize.Y
        h.Font            = isHeader and Enum.Font.GothamBold or Enum.Font.GothamSemibold
        h.TextSize        = isHeader and 20 or 15
        h.TextColor3      = isHeader and _updTheme.Text or _updTheme.Accent
        h.TextXAlignment  = Enum.TextXAlignment.Left
        h.TextWrapped     = true
        h.Text            = headerText
        h.LayoutOrder     = 1
        h.ZIndex          = 7
        h.Parent          = card
        if bodyText and bodyText ~= "" then
            local b = Instance.new("TextLabel")
            b.BackgroundTransparency = 1
            b.Size            = UDim2.new(1, 0, 0, 0)
            b.AutomaticSize   = Enum.AutomaticSize.Y
            b.Font            = Enum.Font.Gotham
            b.TextSize        = 13
            b.TextColor3      = _updTheme.SubText
            b.TextXAlignment  = Enum.TextXAlignment.Left
            b.TextWrapped     = true
            b.Text            = bodyText
            b.LayoutOrder     = 2
            b.ZIndex          = 7
            b.Parent          = card
        end
        _updCards[#_updCards + 1] = card
        return card
    end

    local function _renderUpdates(updates)
        for _, c in ipairs(_updCards) do pcall(function() c:Destroy() end) end
        _updCards = {}
        if type(updates) ~= "table" or #updates == 0 then
            _updCard(1, "No updates yet", "Check back soon.", true)
            return
        end
        local order = 0
        for _, u in ipairs(updates) do
            order = order + 1
            local header = "Update " .. tostring(u.version or "?")
            if type(u.tagline) == "string" and u.tagline ~= "" then
                header = header .. "  —  " .. u.tagline
            end
            local lines = {}
            if type(u.changes) == "table" then
                for _, ch in ipairs(u.changes) do lines[#lines + 1] = "•  " .. tostring(ch) end
            end
            _updCard(order, header, table.concat(lines, "\n"), false)
        end
    end

    local _openUpdates  -- forward declaration (defined below)

    local _updLoading = false
    -- autoOpen=true: open the window only if the latest version is unacknowledged.
    local function _loadUpdates(autoOpen)
        if _updLoading then return end
        _updLoading = true
        task.spawn(function()
            local ok, resp = pcall(requestFunc, { Url = _updUrl, Method = "GET" })
            if ok and resp and (resp.StatusCode == 200 or resp.status_code == 200) then
                local raw = resp.Body or resp.body or ""
                local pok, data = pcall(function() return HttpService:JSONDecode(raw) end)
                if pok and type(data) == "table" and type(data.updates) == "table" then
                    _updCache = data.updates
                    _renderUpdates(data.updates)
                    -- Newest version sits first in the feed (server orders DESC).
                    local newest = data.updates[1] and tostring(data.updates[1].version or "") or ""
                    _updLatestVer = newest
                    if autoOpen and newest ~= "" and newest ~= _updReadSeen() then
                        if _openUpdates then _openUpdates(true) end
                    end
                    _updLoading = false
                    return
                end
            end
            if _updCache then
                _renderUpdates(_updCache)
            else
                _renderUpdates({ { version = "?", tagline = "",
                    changes = { "couldn't reach the update server, try again later" } } })
            end
            _updLoading = false
        end)
    end

    -- Closing OR dragging the window counts as acknowledging the current update.
    _updClose.MouseButton1Click:Connect(function()
        _updMarkSeen()
        _updGui.Enabled = false
    end)
    _updRefresh.MouseButton1Click:Connect(function() _loadUpdates(false) end)

    _openUpdates = function(_skipFetch)
        _updGui.Enabled = true
        _updPanel.BackgroundTransparency = 1
        _updTS:Create(_updPanel, TweenInfo.new(0.2), { BackgroundTransparency = 0.12 }):Play()
        if not _skipFetch then _loadUpdates(false) end
    end

    -- Open from the Settings tab (always available, even with no new update).
    -- Use the global Tabs.Settings (the local SettingsGroup from the Settings
    -- section is out of scope this far down main).
    Tabs.Settings:Button({
        Title = 'Open Updates Window',
        Desc  = 'View the latest pealzware updates',
        Callback = function() _openUpdates(false) end,
    })

    -- On load: fetch and auto-open ONLY if there is an unacknowledged update.
    _renderUpdates({ { version = "", tagline = "loading…", changes = { "fetching latest updates" } } })
    _loadUpdates(true)
end

