                    "material",
                    nil,
                    "anchor",
                    ""
                }
                equiptool("Paint").Script.Event:FireServer(unpack(args))
            end
            localplr.SimulationRadius = math.max(localplr.SimulationRadius,100)
                    until isnetworkowner(p)
        p.CanCollide = true
        coroutine.wrap(function()
            local d = hover(p,cframe)
            repeat
                            until done2
            d(5)
        end)()
        task.wait(1)
        done = true
        local args = {
            p,
            Enum.NormalId.Right,
            getplrpos(),
            "material",
            nil,
            "anchor",
            ""
        }
        equiptool("Paint").Script.Event:FireServer(unpack(args))
