local _smartLowFPSStreak = 0
local _smartHighFPSStreak = 0
local _smartTriggeredBoost = false
SmartOptimizeToggle:OnChanged(function(val)
    if val then
        _smartLowFPSStreak = 0
        _smartHighFPSStreak = 0
    end
end)

task.spawn(function()
    while not false do
        task.wait(1)
        if SmartOptimizeToggle and SmartOptimizeToggle.Value then
            local fps = _measuredFPS
            local ping = getSmoothedPing and getSmoothedPing() or 0

            if fps < 25 then
                _smartLowFPSStreak = _smartLowFPSStreak + 1
                _smartHighFPSStreak = 0
                if _smartLowFPSStreak >= 3 and BoostFPSToggle.Value ~= true then
                    _smartTriggeredBoost = true
                    pcall(function() BoostFPSToggle:SetValue(true) end)
                    WindUI:Notify({ Title = "pealzware", Content = "Smart Optimize: enabling Boost FPS (" .. math.floor(fps) .. " fps)", Duration = 3, Icon = "info" })
                end
            elseif fps > 50 then
                _smartHighFPSStreak = _smartHighFPSStreak + 1
                _smartLowFPSStreak = 0
                if _smartHighFPSStreak >= 5 and _smartTriggeredBoost and BoostFPSToggle.Value == true then
                    _smartTriggeredBoost = false
                    pcall(function() BoostFPSToggle:SetValue(false) end)
                    WindUI:Notify({ Title = "pealzware", Content = "Smart Optimize: disabling Boost FPS (" .. math.floor(fps) .. " fps recovered)", Duration = 3, Icon = "info" })
                end
            else
                if _smartLowFPSStreak > 0 then _smartLowFPSStreak = _smartLowFPSStreak - 1 end
                if _smartHighFPSStreak > 0 then _smartHighFPSStreak = _smartHighFPSStreak - 1 end
            end

            if ping > 200 and not autoPingOptimize then
                autoPingOptimize = true
                WindUI:Notify({ Title = "pealzware", Content = "Smart Optimize: enabling Auto Ping (ping " .. math.floor(ping) .. "ms)", Duration = 3, Icon = "info" })
            end
        end
    end
end)

