local _pw_elementMethods = {
    "Toggle", "Slider", "Dropdown", "Input", "Keybind",
    "Button", "Paragraph", "Colorpicker", "Code",
}

local function _pw_wrapTab(tab)
    if not tab or tab.__pw_wrapped then return tab end
    tab.__pw_wrapped = true
    for _, name in ipairs(_pw_elementMethods) do
        local orig = tab[name]
        if type(orig) == "function" then
            tab[name] = function(self, opts, ...)
                opts = opts or {}
                local userCb = opts.Callback
                local chain  = {}
                local elem
                opts.Callback = function(newVal, ...)

                    if elem and newVal ~= nil and type(elem.Value) ~= "table" then
                        elem.Value = newVal
                    end
                    if userCb then pcall(userCb, newVal, ...) end
                    for _, fn in ipairs(chain) do pcall(fn, newVal, ...) end
                end
                elem = orig(self, opts, ...)
                if type(elem) == "table" then

                    local function _pwResolveValue(eSelf)
                        local v = eSelf.Value
                        if type(v) == "table"
                           and (v.Min ~= nil or v.Max ~= nil or v.Default ~= nil)
                        then
                            return tonumber(v.Default) or tonumber(v.Min) or 0
                        end
                        return v
                    end

                    elem.OnChanged = function(eSelf, fn)
                        if type(fn) == "function" then
                            table.insert(chain, fn)
                            local v = _pwResolveValue(eSelf)
                            if v ~= nil then

                                _pwSuppressNotify = true
                                pcall(fn, v)
                                _pwSuppressNotify = false
                            end
                        end
                        return eSelf
                    end
                    elem.OnClick = elem.OnClick or function(eSelf, fn)
                        if type(fn) == "function" then
                            table.insert(chain, fn)
                        end
                        return eSelf
                    end
                    elem.GetValue = elem.GetValue or function(eSelf) return _pwResolveValue(eSelf) end

                    if not elem.SetValue then
                        elem.SetValue = function(eSelf, v, ...)
                            if eSelf.Set then return eSelf:Set(v, ...) end
                        end
                    end
                    if not elem.SetText then
                        elem.SetText = function(eSelf, t)
                            if eSelf.SetTitle then eSelf:SetTitle(t)
                            elseif eSelf.SetDesc then eSelf:SetDesc(t) end
                        end
                    end
                end
                return elem
            end
        end
    end
    return tab
end

