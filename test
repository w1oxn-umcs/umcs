local function createtraptool()
    local connections = {}
    local tTool = Instance.new("Tool")
    tTool.Name = "Trap Editor Tool"
    tTool.ToolTip = "Select blocks, then players touching them trigger the chosen action"
    tTool.RequiresHandle = true

    local tHandle = Instance.new("Part")
    tHandle.Name = "Handle"
    tHandle.Size = Vector3.new(0.8, 0.8, 2.5)
    tHandle.Color = Color3.fromRGB(255, 100, 200)
    tHandle.Material = Enum.Material.Neon
    tHandle.Reflectance = 0.2
    tHandle.CanCollide = false
    tHandle.Parent = tTool

    local equipped = false

    table.insert(connections, tTool.Equipped:Connect(function()
        equipped = true
        TrapGui.Enabled = true
        for _, modeBlocks in pairs(trapBlocks) do
            for _, data in pairs(modeBlocks) do
                if data.Active and data.SelectionBox then data.SelectionBox.LineThickness = 0.05 end
            end
        end
        _trapUpdateUI()
    end))

    table.insert(connections, tTool.Unequipped:Connect(function()
        if not equipped then return end
        equipped = false
        TrapGui.Enabled = false
        for _, modeBlocks in pairs(trapBlocks) do
            for _, data in pairs(modeBlocks) do
                if data.SelectionBox then data.SelectionBox.LineThickness = -1 end
            end
        end
        if trapSelecting then

            for block, data in pairs(trapBlocks[trapSelMode] or {}) do
                if not data.Active then
                    if data.SelectionBox then pcall(function() data.SelectionBox:Destroy() end) end
                    trapBlocks[trapSelMode][block] = nil
                end
            end
            trapSelecting = false
        end
    end))

    table.insert(connections, mouse.Button1Down:Connect(function()
        if not equipped or not trapSelecting then return end
        local target = mouse.Target
        if not target or not target:IsDescendantOf(cfolder) then return end
        local mode = trapSelMode
        if trapBlocks[mode][target] then
            local data = trapBlocks[mode][target]
            if data.OnTouched then pcall(function() data.OnTouched:Disconnect() end) end
            pcall(function() data.SelectionBox:Destroy() end)
            trapBlocks[mode][target] = nil
            TrapInfo.Text = "Block removed from " .. mode
        else
            local bbox = Instance.new("SelectionBox")
            bbox.Color3 = Color3.fromRGB(0, 170, 255)
            bbox.LineThickness = 0.1
            bbox.SurfaceColor3 = Color3.fromRGB(13, 105, 172)
            bbox.SurfaceTransparency = 0.7
            bbox.Adornee = target
            bbox.Parent = game.CoreGui
            table.insert(tools, { bbox })
            trapBlocks[mode][target] = { SelectionBox = bbox, Block = target, Active = false, OnTouched = nil }
            TrapInfo.Text = "Added to " .. mode .. " (click Finish)"
        end
        _trapUpdateUI()
    end))

    table.insert(connections, tTool.AncestryChanged:Connect(function()
        if not tTool.Parent or not tTool.Parent.Parent then
            for _, c in pairs(connections) do pcall(function() c:Disconnect() end) end
            TrapGui.Enabled = false
        end
    end))

    table.insert(tools, { tTool })
    tTool.Parent = localplr.Backpack
    return tTool
end

