do -- Server / Enlighten chat alerts

local _JOIN_CHAT_DEFAULT      = "\u{1F44B} {username} joined the server!"
local _LEAVE_CHAT_DEFAULT     = "\u{1F44B} {username} left the server!"
local _ENLIGHTEN_TOOL_NAME    = "The Arkenstone"
local _ENLIGHTEN_CHAT_DEFAULT = "\u{2728} {username} got {tool}!"

local _joinAlertEnabled      = false
local _leaveAlertEnabled     = false
local _enlightenAlertEnabled = false

chatAlertServiceAlive = true
chatAlertEnlightenConns = chatAlertEnlightenConns or {}
chatAlertEnlightenState = chatAlertEnlightenState or {}

local _serverAlertGroup = Tabs.Server
Tabs.Server:Section({ Title = 'Server Chat Alerts', Icon = "message-circle", TextSize = 22 })

local _joinAlertToggle = _serverAlertGroup:Toggle({
    Title = 'Join Chat Message',
