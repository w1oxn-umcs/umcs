local function _trapApplySpleef(block, _player)
    if not block or not block.Parent or _trapTagged(block) or block.CanCollide ~= true then return end
    _trapTag(block, 6)
    local origColor = block.Color
    _trapFirePaint({ block, Enum.NormalId.Top, getplrpos(), "both \u{1F91D}",
                     Color3.new(1, 0, 0), "collide", "" })
    task.delay(5, function()
        _trapFirePaint({ block, Enum.NormalId.Top, getplrpos(), "both \u{1F91D}",
                         origColor, "collide", "" })
    end)
end

local function _trapApplyDelete(block, _player)
    if not block or not block.Parent or _trapTagged(block) or block.CanCollide ~= true then return end
    _trapTag(block, 2)
    if isog then ExecuteDeleteOG(block) else ExecuteDelete(block) end
end

local function _trapApplyToxify(block, _player)
    if not block or not block.Parent or _trapTagged(block) or block.CanCollide ~= true then return end
    _trapTag(block, 3)
    _trapFirePaint({ block, Enum.NormalId.Top, getplrpos(), "material",
                     Color3.new(1, 0, 0), "toxic", "" })
end

local function _trapApplyDisco(block, _player)
    if not block or not block.Parent or _trapTagged(block) then return end
    _trapTag(block, 0.2)
    trapDisco[block] = (trapDisco[block] or 0) + 1
    local hue = ((trapDisco[block] * 25) % 255) / 255
    _trapFirePaint({ block, Enum.NormalId.Top, getplrpos(), "both \u{1F91D}",
                     Color3.fromHSV(hue, 1, 1), "neon", "" })
end

local _trapChatConn = nil
local function _ensureTrapChatHook()
    if _trapChatConn then return end
    local tc = game:GetService("TextChatService")
    local channel = tc.TextChannels and tc.TextChannels:FindFirstChild("RBXGeneral")
    if not channel then return end
    _trapChatConn = channel.MessageReceived:Connect(function(mdata)
        local txt = (mdata and mdata.Text or ""):lower()
        if txt == "" then return end
        for block, data in pairs(trapBlocks.Guess) do
            if data.Active and block and block.Parent and not _trapTagged(block) then
                local keywords = trapGuess[block] or {}
                local matched = false
                for _, kw in ipairs(keywords) do
                    if kw ~= "" and string.find(txt, kw, 1, true) then matched = true; break end
                end
                if matched then
                    _trapTag(block, 6)
                    local origColor = block.Color
                    _trapFirePaint({ block, Enum.NormalId.Top, getplrpos(), "material",
                                     Color3.new(1, 0, 0), "glass", "" })
                    task.wait(0.1)
                    _trapFirePaint({ block, Enum.NormalId.Top, getplrpos(), "material",
                                     Color3.new(1, 0, 0), "collide", "" })
                    task.delay(5, function()
                        _trapFirePaint({ block, Enum.NormalId.Top, getplrpos(), "material",
                                         origColor, "plastic", "" })
                        task.wait(0.1)
                        _trapFirePaint({ block, Enum.NormalId.Top, getplrpos(), "material",
                                         origColor, "collide", "" })
                    end)
                end
            end
        end
    end)
    trackScriptConnection(_trapChatConn)
end

local _trapApplyByMode = {
    Spleef = _trapApplySpleef,
    Delete = _trapApplyDelete,
    Toxify = _trapApplyToxify,
    Disco  = _trapApplyDisco,

}

createToolButton(_trapPanel.frame, "Select Blocks", 0.46, 0.03, 0.94, function()
    if trapSelecting then return end
    if trapMode == "Guess" then

    end
    trapSelecting = true
    trapSelMode = trapMode
    for _, data in pairs(trapBlocks[trapSelMode]) do
        if data.SelectionBox then data.SelectionBox.LineThickness = 0.1 end
    end
    TrapInfo.Text = "Click " .. trapSelMode .. " blocks. Finish when done."
end)

createToolButton(_trapPanel.frame, "Finish", 0.56, 0.03, 0.45, function()
    if not trapSelecting then TrapInfo.Text = "Not in selection mode"; return end
    trapSelecting = false
    local mode = trapSelMode
    local activeCol = _trapColors[mode] or Color3.fromRGB(255, 255, 255)

    local guessKW
    if mode == "Guess" then
        local raw = trapGuessBox.Text or ""
        guessKW = {}
        for _, part in ipairs(string.split(raw, "|")) do
            local trimmed = part:match("^%s*(.-)%s*$"):lower()
            if trimmed ~= "" then table.insert(guessKW, trimmed) end
        end
        if #guessKW == 0 then
            TrapInfo.Text = "No Guess words set — type them above"
            return
        end
        _ensureTrapChatHook()
    end

    local count = 0
    for block, data in pairs(trapBlocks[mode]) do
        if data.SelectionBox then data.SelectionBox.LineThickness = -1 end
        if not data.Active then
            data.Active = true
            if data.SelectionBox then
                data.SelectionBox.Color3        = activeCol
                data.SelectionBox.SurfaceColor3 = activeCol
            end
            if mode == "Guess" then
                trapGuess[block] = guessKW
            else

                data.OnTouched = block.Touched:Connect(function(hit)
                    if not trapBlocks[mode] or not trapBlocks[mode][block] then return end
                    local hitPlr = _trapResolvePlayer(hit)
                    if not hitPlr or hitPlr == plr then return end
                    if not hitPlr.Character or not hitPlr.Character:FindFirstChildOfClass("Humanoid") then return end
                    local fn = _trapApplyByMode[mode]
                    if fn then task.spawn(fn, block, hitPlr) end
                end)
            end
        end
        count = count + 1
    end
    TrapInfo.Text = mode .. " active: " .. count .. " block(s)"
    _trapUpdateUI()
end)

