        pcall(function() _leaveMessageInput:SetValue(_LEAVE_CHAT_DEFAULT) end)
        _joinMessageInput.Value = _JOIN_CHAT_DEFAULT
        _leaveMessageInput.Value = _LEAVE_CHAT_DEFAULT
        WindUI:Notify({ Title = "pealzware", Content = "Join/leave messages reset", Duration = 3, Icon = "info" })
    end,
})

local _enlightenAlertGroup = Tabs.Enlighten
Tabs.Enlighten:Section({ Title = 'Chat Alert', Icon = "message-circle", TextSize = 22 })

local _enlightenAlertToggle = _enlightenAlertGroup:Toggle({
    Title = 'Enlighten Chat Message',
    Default = false,
    Desc = 'Sends a chat message when a player gets The Arkenstone'
})

local _enlightenMessageInput = _enlightenAlertGroup:Input({
    Value = _ENLIGHTEN_CHAT_DEFAULT,
    Numeric = false,
    Finished = true,
    Title = 'Enlighten Message:',
    Placeholder = _ENLIGHTEN_CHAT_DEFAULT,
    Desc = 'Tokens: {username}, {displayname}, {tool}'
})

_enlightenAlertGroup:Button({
    Title = 'Reset Enlighten Default',
    Callback = function()
        pcall(function() _enlightenMessageInput:SetValue(_ENLIGHTEN_CHAT_DEFAULT) end)
        _enlightenMessageInput.Value = _ENLIGHTEN_CHAT_DEFAULT
        WindUI:Notify({ Title = "pealzware", Content = "Enlighten message reset", Duration = 3, Icon = "info" })
    end,
})

_joinAlertToggle:OnChanged(function(value)
    _joinAlertEnabled = value == true
end)

_leaveAlertToggle:OnChanged(function(value)
    _leaveAlertEnabled = value == true
end)

_enlightenAlertToggle:OnChanged(function(value)
    _enlightenAlertEnabled = value == true
end)

local function _trimChatAlertText(text)
    return (tostring(text or ""):match("^%s*(.-)%s*$")) or ""
end

local function _replaceChatAlertToken(text, token, value)
    local pattern = token:gsub("([^%w])", "%%%1")
    local replacement = tostring(value or ""):gsub("%%", "%%%%")
    return (text:gsub(pattern, replacement))
end

local function _formatChatAlertMessage(template, player, fallback, extra)
    local msg = _trimChatAlertText(template)
    if msg == "" then msg = fallback end
    extra = extra or {}

    local username = player and player.Name or "Unknown"
    local displayName = (player and player.DisplayName and player.DisplayName ~= "") and player.DisplayName or username
    local userId = player and player.UserId or 0

    msg = _replaceChatAlertToken(msg, "{username}", username)
    msg = _replaceChatAlertToken(msg, "{name}", username)
    msg = _replaceChatAlertToken(msg, "{displayname}", displayName)
    msg = _replaceChatAlertToken(msg, "{userid}", tostring(userId))
    msg = _replaceChatAlertToken(msg, "{tool}", tostring(extra.tool or _ENLIGHTEN_TOOL_NAME))
    return _trimChatAlertText(msg)
end

local function _sendChatAlertMessage(text)
    if not chatAlertServiceAlive then return end
    local msg = _trimChatAlertText(text)
    if msg == "" then return end

    task.spawn(function()
        if not chatAlertServiceAlive then return end
        local sent = false

        pcall(function()
            local tcs = game:GetService("TextChatService")
            local channels = tcs and tcs:FindFirstChild("TextChannels")
            local general = channels and channels:FindFirstChild("RBXGeneral")
            if general then
                general:SendAsync(msg)
                sent = true
            end
        end)

        if sent or not chatAlertServiceAlive then return end

        pcall(function()
            local events = game:GetService("ReplicatedStorage"):FindFirstChild("DefaultChatSystemChatEvents")
            local say = events and events:FindFirstChild("SayMessageRequest")
            if say then
                say:FireServer(msg, "All")
            end
        end)
    end)
end

local function _sendJoinAlert(player)
    if not _joinAlertEnabled or player == plr then return end
    _sendChatAlertMessage(_formatChatAlertMessage(_joinMessageInput.Value, player, _JOIN_CHAT_DEFAULT))
end

local function _sendLeaveAlert(player)
    if not _leaveAlertEnabled or player == plr then return end
    _sendChatAlertMessage(_formatChatAlertMessage(_leaveMessageInput.Value, player, _LEAVE_CHAT_DEFAULT))
end

local function _sendEnlightenAlert(player)
    if not _enlightenAlertEnabled then return end
    _sendChatAlertMessage(_formatChatAlertMessage(
        _enlightenMessageInput.Value,
        player,
        _ENLIGHTEN_CHAT_DEFAULT,
        { tool = _ENLIGHTEN_TOOL_NAME }
    ))
end

local function _hasChatAlertEnlighten(player)
    if not player then return false end

    local backpack = player:FindFirstChild("Backpack")
    if backpack and backpack:FindFirstChild(_ENLIGHTEN_TOOL_NAME) then return true end

    local character = player.Character
    if character and character:FindFirstChild(_ENLIGHTEN_TOOL_NAME) then return true end

    local ok, hasArken = pcall(function()
        return player:GetAttribute("Arken")
    end)
    return ok and hasArken == true
end

local function _setChatAlertEnlighten(player, hasTool, announce)
    if not player then return end

    local userId = player.UserId
    local hadTool = chatAlertEnlightenState[userId] == true
    chatAlertEnlightenState[userId] = hasTool == true

    if hasTool and not hadTool and announce then
        _sendEnlightenAlert(player)
    end
end

local function _recheckChatAlertEnlighten(player, announce)
    task.spawn(function()
        task.wait(0.15)
        if not chatAlertServiceAlive or not player or player.Parent ~= Players then return end
        _setChatAlertEnlighten(player, _hasChatAlertEnlighten(player), announce == true)
    end)
end

local function _stopWatchingChatAlertEnlighten(player)
    if not player then return end
    local userId = player.UserId
    local conns = chatAlertEnlightenConns[userId]
    if conns then
        disconnectConnectionList(conns)
        chatAlertEnlightenConns[userId] = nil
    end
    chatAlertEnlightenState[userId] = nil
end

local function _watchChatAlertEnlighten(player, announceInitial)
    if not player or chatAlertEnlightenConns[player.UserId] then return end

    local conns = {}
    local watchedContainers = setmetatable({}, { __mode = "k" })
    chatAlertEnlightenConns[player.UserId] = conns

    local function _addConn(conn)
        if conn then table.insert(conns, conn) end
        return conn
    end

    local function _watchContainer(container)
        if not container or watchedContainers[container] then return end
        watchedContainers[container] = true

        _addConn(container.ChildAdded:Connect(function(item)
            if not chatAlertServiceAlive then return end
            if item and item.Name == _ENLIGHTEN_TOOL_NAME then
                _setChatAlertEnlighten(player, true, true)
            end
        end))

        _addConn(container.ChildRemoved:Connect(function(item)
            if not chatAlertServiceAlive then return end
            if item and item.Name == _ENLIGHTEN_TOOL_NAME then
                _recheckChatAlertEnlighten(player, true)
            end
        end))
    end

    local backpack = player:FindFirstChild("Backpack")
    if backpack then _watchContainer(backpack) end
    if player.Character then _watchContainer(player.Character) end

    _addConn(player.ChildAdded:Connect(function(child)
        if not chatAlertServiceAlive then return end
        if child and child.Name == "Backpack" then
            _watchContainer(child)
            _recheckChatAlertEnlighten(player, true)
        end
    end))

    _addConn(player.CharacterAdded:Connect(function(character)
        task.spawn(function()
            task.wait(0.25)
            if not chatAlertServiceAlive then return end
            _watchContainer(character)
            _recheckChatAlertEnlighten(player, true)
        end)
    end))

    pcall(function()
        _addConn(player:GetAttributeChangedSignal("Arken"):Connect(function()
            if not chatAlertServiceAlive then return end
            _recheckChatAlertEnlighten(player, true)
        end))
    end)

    _recheckChatAlertEnlighten(player, announceInitial == true)
end

for _, player in ipairs(Players:GetPlayers()) do
    _watchChatAlertEnlighten(player, false)
end

trackScriptConnection(Players.PlayerAdded:Connect(function(player)
    _watchChatAlertEnlighten(player, true)
    task.spawn(function()
        task.wait(0.2)
        if not chatAlertServiceAlive or not player or player.Parent ~= Players then return end
        _sendJoinAlert(player)
    end)
end))

trackScriptConnection(Players.PlayerRemoving:Connect(function(player)
    if chatAlertServiceAlive then
        _sendLeaveAlert(player)
    end
    _stopWatchingChatAlertEnlighten(player)
end))

end


do

local _enlightenPopout = Tabs.Enlighten
local _enlBtn = setmetatable({}, { __index = function() return function() end end })
_enlightenPopout:Section({ Title = 'Enlighten Finder', Icon = "sparkles", TextSize = 22 })

local _enlHeaderGroup = _enlightenPopout; _enlightenPopout:Section({ Title = 'Status', TextSize = 20 })
local _enlStatusLabel  = _enlHeaderGroup:Paragraph({ Title = 'Watching — no players found' })

local _enlPlayersGroup = _enlightenPopout; _enlightenPopout:Section({ Title = 'Players with Enlighten', TextSize = 20 })

local _enlCards       = {}
_enlWatchConns        = {}
local _enlSpectating  = nil

local function _updateStatus()
    local count = 0
    for _ in pairs(_enlCards) do count = count + 1 end
    if count == 0 then
        _enlStatusLabel:SetText('Watching — no players found')
    else
        _enlStatusLabel:SetText('Active: ' .. count .. ' player(s) with Enlighten')
    end
end

local _ENL_SPEC_IDLE   = Color3.fromRGB(0, 65, 160)
local _ENL_SPEC_ACTIVE = Color3.fromRGB(190, 50, 50)
local _ENL_TP_COLOR    = Color3.fromRGB(0, 85, 210)

local function _makeEnlCard(player)
    if _enlCards[player.UserId] then return end

    local headshot = 'rbxthumb://type=AvatarHeadShot&id=' .. player.UserId .. '&w=150&h=150'
    local nameLine = player.Name
    if player.DisplayName ~= player.Name then
        nameLine = player.DisplayName .. '  @' .. player.Name
    end

    local paragraph = _enlPlayersGroup:Paragraph({
        Title     = nameLine,
        Desc      = '<font color="#7BC4FF">●</font>  Holding Enlighten',
        Image     = headshot,
        ImageSize = 42,
    })

    local tpBtn = _enlPlayersGroup:Button({
        Title = "Teleport to " .. player.Name,
        Icon  = "move",
        Callback = function()
            pcall(function()
                local myChar    = plr.Character
                local theirChar = player.Character
                if myChar and theirChar then
                    local myHRP    = myChar:FindFirstChild('HumanoidRootPart')
                    local theirHRP = theirChar:FindFirstChild('HumanoidRootPart')
                    if myHRP and theirHRP then
                        myHRP.CFrame = theirHRP.CFrame * CFrame.new(3, 0, 0)
                        WindUI:Notify({ Title = "pealzware", Content = 'Teleported to ' .. player.Name, Duration = 2, Icon = "info" })
                    end
                end
            end)
        end,
    })

    local specBtn
    specBtn = _enlPlayersGroup:Button({
        Title = "Spectate " .. player.Name,
        Icon  = "eye",
        Callback = function()
            pcall(function()
                if _enlSpectating == player then
                    _enlSpectating = nil
                    local myChar = plr.Character
                    local myHum  = myChar and myChar:FindFirstChildOfClass('Humanoid')
                    if myHum then
                        workspace.CurrentCamera.CameraSubject = myHum
                    end
                    if specBtn.SetTitle then pcall(function() specBtn:SetTitle("Spectate " .. player.Name) end) end
                    WindUI:Notify({ Title = "pealzware", Content = 'Stopped spectating', Duration = 2, Icon = "info" })
                else
                    local theirChar = player.Character
                    if theirChar then
                        local theirHum = theirChar:FindFirstChildOfClass('Humanoid')
                        if theirHum then

                            if _enlSpectating and _enlCards[_enlSpectating.UserId] then
                                local prev = _enlCards[_enlSpectating.UserId]
                                if prev.spec and prev.spec.SetTitle then
                                    pcall(function() prev.spec:SetTitle("Spectate " .. _enlSpectating.Name) end)
                                end
                            end
                            _enlSpectating = player
                            workspace.CurrentCamera.CameraSubject = theirHum
                            if specBtn.SetTitle then pcall(function() specBtn:SetTitle("◉ Spectating " .. player.Name) end) end
                            WindUI:Notify({ Title = "pealzware", Content = 'Spectating ' .. player.Name, Duration = 2, Icon = "info" })
                        else
                            WindUI:Notify({ Title = "pealzware", Content = player.Name .. ' has no humanoid', Duration = 2, Icon = "info" })
                        end
                    else
                        WindUI:Notify({ Title = "pealzware", Content = player.Name .. ' has no character', Duration = 2, Icon = "info" })
                    end
                end
            end)
        end,
    })

    _enlCards[player.UserId] = { paragraph = paragraph, tp = tpBtn, spec = specBtn }
end

local function _removeEnlCard(userId)
    local c = _enlCards[userId]
    if not c then return end
    for _, e in pairs({ c.paragraph, c.tp, c.spec }) do
        if e and e.Destroy then pcall(function() e:Destroy() end) end
    end
    _enlCards[userId] = nil
end

local function _hasEnlighten(player)
    local bp = player:FindFirstChild('Backpack')
    if bp and bp:FindFirstChild('The Arkenstone') then return true end
    if player.Character and player.Character:FindFirstChild('The Arkenstone') then return true end
    if player:GetAttribute('Arken') == true then return true end
    return false
end

local function _onEnlightenGained(player)
    if not _enlCards[player.UserId] then
        _makeEnlCard(player)
        _updateStatus()
        WindUI:Notify({ Title = "pealzware", Content = 'Enlighten: ' .. player.Name .. ' has The Arkenstone!', Duration = 6, Icon = "info" })
    end
end

local function _onEnlightenLost(player)
    if _enlCards[player.UserId] then
        if _enlSpectating == player then
            _enlSpectating = nil
            pcall(function()
                local myHum = plr.Character and plr.Character:FindFirstChildOfClass('Humanoid')
                workspace.CurrentCamera.CameraSubject = myHum
            end)
        end
        _removeEnlCard(player.UserId)
        _updateStatus()
    end
end

local function _recheckEnlighten(player)
    task.wait(0.15)
    if _hasEnlighten(player) then
        _onEnlightenGained(player)
    else
        _onEnlightenLost(player)
    end
end

local function _watchEnlightenFor(player)
    if player == plr then return end
    local conns = {}

    local function _watchBp(bp)
        table.insert(conns, bp.ChildAdded:Connect(function(item)
            if item.Name == 'The Arkenstone' then _onEnlightenGained(player) end
        end))
        table.insert(conns, bp.ChildRemoved:Connect(function(item)
            if item.Name == 'The Arkenstone' then _recheckEnlighten(player) end
        end))
    end

    local function _watchChar(char)
        table.insert(conns, char.ChildAdded:Connect(function(item)
            if item.Name == 'The Arkenstone' then _onEnlightenGained(player) end
        end))
        table.insert(conns, char.ChildRemoved:Connect(function(item)
            if item.Name == 'The Arkenstone' then _recheckEnlighten(player) end
        end))
    end

    local bp = player:FindFirstChild('Backpack')
    if bp then _watchBp(bp) end

    table.insert(conns, player.ChildAdded:Connect(function(child)
        if child.Name == 'Backpack' then _watchBp(child) end
    end))

    if player.Character then _watchChar(player.Character) end
    table.insert(conns, player.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        _recheckEnlighten(player)
        _watchChar(char)
    end))

    _enlWatchConns[player.UserId] = conns
    _recheckEnlighten(player)
end

for _, pl in ipairs(Players:GetPlayers()) do
    task.spawn(_watchEnlightenFor, pl)
end

trackScriptConnection(Players.PlayerAdded:Connect(function(pl)
    task.wait(2)
    _watchEnlightenFor(pl)
end))

trackScriptConnection(Players.PlayerRemoving:Connect(function(pl)
    local conns = _enlWatchConns[pl.UserId]
