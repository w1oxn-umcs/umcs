local function _repFirePaint(args)
    local char = plr.Character
    if not char then return false end
    local pt = char:FindFirstChild("Paint") or plr.Backpack:FindFirstChild("Paint")
    if not pt then return false end
    if pt.Parent ~= char then pt.Parent = char; task.wait() end
    local ev = pt:FindFirstChild("origevent")
    if ev then return pcall(function() ev:Invoke(table.unpack(args)) end) end
    if pt:FindFirstChild("Script") and pt.Script:FindFirstChild("Event") then
        return pcall(function() pt.Script.Event:FireServer(table.unpack(args)) end)
    end
    return false
end

