local function _pwResolveRow(parent, yPos)
    local rowKey = math.floor((yPos or 0) * 100 + 0.5)
    local prevKey    = parent:GetAttribute("PWLastRowKey") or -1
    local prevBottom = parent:GetAttribute("PWLastRowBottomOffset") or 0
    local y
    if rowKey == prevKey then

        y = prevBottom - _pwElementH
    else

        y = prevBottom + (prevKey >= 0 and _pwRowGap or 0)
        parent:SetAttribute("PWLastRowKey", rowKey)
        parent:SetAttribute("PWLastRowBottomOffset", y + _pwElementH)
    end
    return y
end

